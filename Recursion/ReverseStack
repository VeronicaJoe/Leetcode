class Solution {
    //Brute Force: Using a List
    public static void reverseStack(Stack<Integer> st) {
        // code here
        List<Integer> list = new ArrayList<>();
        while(!st.isEmpty())
        {
            list.add(st.pop());
        }
        for(int num:list)
        {
            st.push(num);
        }
    }
}
